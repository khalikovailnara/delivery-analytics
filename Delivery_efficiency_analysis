SELECT 
	CASE
		WHEN delayed_delivery_flag = false AND cancellation_flag = false THEN 'Успешная доставка'
		WHEN cancellation_flag = true THEN 'Отменён заказ'
		WHEN delayed_delivery_flag = true THEN 'Задержанная доставка'
	END AS Статус_доставки,

	COUNT(*) AS Количество_заказов,
	ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER(), 2) AS Процент_от_общего_числа,
	AVG(order_value) AS Средняя_стоимость_заказа,
	AVG(tip_amount) AS Средняя_сумма_чаевых
	
FROM food_delivery_analytics_cleaned
GROUP BY Статус_доставки
ORDER BY Количество_заказов DESC;

