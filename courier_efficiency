WITH Статистика_курьеров AS (
	SELECT
		delivery_partner_experience_years AS Опыт_работы,
		COUNT(*) AS Доставки,
		AVG(delivery_time_minutes) AS Среднее_время_доставки,
		AVG(delivery_partner_rating) AS Средний_рейтинг,
		AVG(delivery_efficiency_score) AS Оценка_эффективности_доставки,
		ROUND(100.0 * SUM(CASE WHEN delayed_delivery_flag THEN 1 ELSE 0 END) / COUNT(*),2) AS Процент_задержек_доставки
	FROM food_delivery_analytics_cleaned
	WHERE delivery_partner_experience_years IS NOT NULL
	GROUP BY delivery_partner_experience_years
)
SELECT Опыт_работы, Доставки, Среднее_время_доставки, Средний_рейтинг, Оценка_эффективности_доставки, Процент_задержек_доставки,
	CASE
		WHEN Оценка_эффективности_доставки > 80 AND Процент_задержек_доставки < 10 THEN 'Отличный курьер'
		WHEN Оценка_эффективности_доставки > 60 THEN 'Хороший'
		WHEN Процент_задержек_доставки > 30 THEN 'Требует обучения'
		ELSE 'Средний'
	END AS Категория_работника
FROM Статистика_курьеров
ORDER BY Оценка_эффективности_доставки DESC;
