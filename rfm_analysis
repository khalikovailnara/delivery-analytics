WITH Клиентские_метрики AS (
	SELECT 
		order_id, customer_age, customer_loyalty_score, order_value, tip_amount,
		CASE
			WHEN customer_loyalty_score >= 7 THEN 'VIP'
			WHEN customer_loyalty_score >=4 THEN 'Серебро'
			ELSE 'Бронза'
		END AS Сегмент_клиента
	FROM food_delivery_analytics_cleaned	
)
SELECT 
	Сегмент_клиента,
	COUNT(*) AS Количество_заказов,
	AVG(order_value) AS Средняя_стоимость_заказа,
	AVG(tip_amount) AS Средняя_сумма_чаевых,
	ROUND(100.0 * SUM(CASE WHEN tip_amount > 0 THEN 1 ELSE 0 END) / COUNT(*),2) AS Процент_заказов_с_чаевыми
FROM Клиентские_метрики
GROUP BY Сегмент_клиента
ORDER BY Средняя_стоимость_заказа DESC;
